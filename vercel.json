{
  "version": 2,
  "public": true,
  "installCommand": "npm install -g pnpm && pnpm install",
  "buildCommand": "pnpm build:web",
  "outputDirectory": "dist-web",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ]
}
